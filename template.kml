<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<!-- 3D Tiling Pipeline KML template for use with altitudeMode=clampToGround -->
<Document>
  <Placemark>
    <name>{name}</name>
    <Model>
    <Location>
      <longitude>{longitude}</longitude>
      <latitude>{latitude}</latitude>
      <altitude>{altitude}</altitude>
    </Location>
    <altitudeMode>clampToGround</altitudeMode>
    <Orientation>
      <heading>0</heading>
      <tilt>0</tilt>
      <roll>0</roll>
    </Orientation>
    <Scale>
      <x>10.0</x>
      <y>10.0</y>
      <z>11.1</z>
    </Scale>
    <Link>
      <href>{href}</href>
    </Link>
    </Model>
	<ExtendedData>
	  <Data name="ftr_cde">
		  <value>{FTR_CDE}</value>
	  </Data>
	  <Data name="ftr_idn">
		  <value>{FTR_IDN}</value>
	  </Data>
	  <Data name="hjd_cde">
		  <value>{HJD_CDE}</value>
	  </Data>
    <Data name="mng_cde">
		  <value>{MNG_CDE}</value>
	  </Data>
    <Data name="sht_num">
		  <value>{SHT_NUM}</value>
	  </Data>
    <Data name="sec_idn">
		  <value>{SEC_IDN}</value>
	  </Data>
    <Data name="cnt_num">
		  <value>{CNT_NUM}</value>
	  </Data>
    <Data name="tre_ymd">
		  <value>{TRE_YMD}</value>
	  </Data>
    <Data name="tre_cde">
		  <value>{TRE_CDE}</value>
	  </Data>
    <Data name="tre_dia">
		  <value>{TRE_DIA}</value>
	  </Data>
    <Data name="ptc_cde">
		  <value>{PTC_CDE}</value>
	  </Data>
    <Data name="sys_chk">
		  <value>{SYS_CHK}</value>
	  </Data>
    <Data name="upd_nam">
		  <value>{UPD_NAM}</value>
	  </Data>
    <Data name="upd_ymd">
		  <value>{UPD_YMD}</value>
	  </Data>
	</ExtendedData>
  </Placemark>
</Document>
</kml>
